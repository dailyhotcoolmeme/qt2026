# ================================
# myamen 환경변수
# 이 파일을 .env로 복사 후 실제 값 입력
# .env는 절대 git에 올리지 말 것
# ================================

# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Cloudflare Workers API
EXPO_PUBLIC_API_BASE_URL=https://your-worker.your-subdomain.workers.dev

# Cloudflare R2 (이미지 스토리지)
EXPO_PUBLIC_R2_BASE_URL=https://your-bucket.r2.dev

# Google OAuth
# Google Cloud Console에서 발급
# OAuth 2.0 클라이언트 ID → iOS 앱 / Android 앱 각각 생성
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your-android-client-id.apps.googleusercontent.com

# 카카오 OAuth
# https://developers.kakao.com 에서 발급
EXPO_PUBLIC_KAKAO_APP_KEY=your-kakao-native-app-key
