{
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(git push --force *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/Desktop/myamen && npx tsc --noEmit 2>&1 | head -30 || true"
          }
        ]
      }
    ]
  }
}
